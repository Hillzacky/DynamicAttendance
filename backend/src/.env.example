# Server
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1
BASE_URL=http://localhost:3000

# Database PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=attendance_db
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_POOL_MAX=20
DB_IDLE_TIMEOUT=30000
DB_CONN_TIMEOUT=2000
DB_SSL=false

# JWT
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your-refresh-secret-key-minimum-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGIN=*

# Bcrypt
BCRYPT_ROUNDS=10

# Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Storage (local | s3)
STORAGE_TYPE=local

# AWS S3 (optional)
AWS_BUCKET=
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY=
AWS_SECRET_KEY=